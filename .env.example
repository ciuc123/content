# Environment variables example for Ideas Content Engine

# AI provider
# For ManualProvider (paste Copilot output in the UI) no key is required.
# Options: manual, github, openai
AI_PROVIDER=manual

# Optional: path to Copilot CLI binary (or leave empty to use `npx @githubnext/copilot-cli`)
COPILOT_CLI_BIN=

OPENAI_API_KEY=

# Clerk Authentication
# Get from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (optional for production)
# Get from https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Enable Supabase for multi-user support (set to false to use file-based storage for dev)
USE_SUPABASE=false

# GitHub (used to create PRs in target repo)
GITHUB_TOKEN=
GITHUB_TARGET_REPO=ciuc123/ciuc123.github.io

# Local dev flags
# DEV_AUTH_DISABLED: When true, bypasses Clerk authentication in middleware and uses 'dev-user' as userId.
#   - Set to true for local development without Clerk setup
#   - Set to false for production or testing with real authentication
DEV_AUTH_DISABLED=true

# USE_LOCAL_KNOWLEDGE: When true, reads CV/experience from local files instead of Supabase.
#   - Set to true for faster local development
#   - Set to false to use Supabase for knowledge data (production mode)
USE_LOCAL_KNOWLEDGE=true

# GITHUB_MOCK: When true, publishes to local content/posts folder instead of creating GitHub PRs.
#   - Set to true for rapid local testing without GitHub API calls
#   - Set to false to create real pull requests to GITHUB_TARGET_REPO
GITHUB_MOCK=true

# Database (for docker-compose)
POSTGRES_USER=ideas
POSTGRES_PASSWORD=ideas
POSTGRES_DB=ideas_dev
DATABASE_URL=postgresql://ideas:ideas@db:5432/ideas_dev

# Optional manual provider helper (can be used for quick local testing)
# Set this to a canned response for the ManualProvider
MANUAL_AI_RESPONSE=

# GitHub Copilot API Integration (Optional)
# Enable AI-powered generation via GitHub Copilot API
COPILOT_ENABLED=true
# Use OpenAI as the Copilot backend (alternative to direct API)
COPILOT_USE_OPENAI=false

